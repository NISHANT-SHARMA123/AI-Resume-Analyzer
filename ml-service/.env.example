# ═══════════════════════════════════════════════════
#  ResumeAI ML Service — Environment Variables
#  Copy this file to ml-service/.env and fill in values
# ═══════════════════════════════════════════════════

# OpenAI API Key (optional but recommended for best AI feedback)
# Get yours from: https://platform.openai.com/api-keys
# If left empty, the app uses rule-based feedback instead
OPENAI_API_KEY=your_openai_api_key_here

# Flask settings
FLASK_ENV=development
FLASK_DEBUG=1
